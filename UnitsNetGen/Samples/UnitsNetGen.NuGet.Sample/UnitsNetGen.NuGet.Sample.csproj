<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>

    <!-- The packaged analyzer brings its private dependencies; repository ProjectReference plumbing must stay off. -->
    <UnitsNetGenSampleUsePackagedAnalyzer>true</UnitsNetGenSampleUsePackagedAnalyzer>
  </PropertyGroup>

  <!-- Repository-only automation that packs and restores the newest local package. -->
  <Import Project="../UnitsNetGen.LocalPackages.targets" />

  <PropertyGroup>
    <RestoreSources>$(UnitsNetGenSampleLocalFeed)</RestoreSources>
  </PropertyGroup>
  <ItemGroup>
    <UnitsNetGenDefinition Include="HowMuch.unitsnet.json" />
    <PackageReference Include="UnitsNetGen" Version="$(UnitsNetGenSampleLocalVersion)" />
  </ItemGroup>
</Project>
