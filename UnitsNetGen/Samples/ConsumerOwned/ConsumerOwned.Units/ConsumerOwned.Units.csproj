<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../../DefinitionPackages/Fictional.Measurements.Definitions/Fictional.Measurements.Definitions.csproj" />
    <ProjectReference Include="../../../UnitsNetGen/UnitsNetGen.csproj" />
    <ProjectReference Include="../../../UnitsNetGen.Generator/UnitsNetGen.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup>
    <!-- A packed definition package supplies these through its build props. Link them explicitly
         only because this repository sample uses a ProjectReference instead of PackageReference. -->
    <UnitsNetGenDefinition Include="../../DefinitionPackages/Fictional.Measurements.Definitions/Definitions/*.unitsnet.json" />
    <UnitsNetGenRelation Include="../../DefinitionPackages/Fictional.Measurements.Definitions/Definitions/*.unitsnet.relations.json" />
  </ItemGroup>
</Project>
