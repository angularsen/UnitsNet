<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="../UnitsNetGen.Compatibility.Shared/CompatibilityScenario.cs" Link="CompatibilityScenario.cs" />
    <Compile Include="../UnitsNetGen.Compatibility.Shared/Program.cs" Link="Program.cs" />
    <ProjectReference Include="../../UnitsNetGen/UnitsNetGen.csproj" />
    <ProjectReference Include="../../UnitsNetGen.Generator/UnitsNetGen.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
