<Project>
  <!-- Definition packages contribute compile-time data only to the project that references them. -->
  <ItemGroup>
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)definitions/*.unitsnet.json"
                     UnitsNetGenDefinition="true" />
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)definitions/*.unitsnet.relations.json"
                     UnitsNetGenRelation="true" />
  </ItemGroup>
</Project>
