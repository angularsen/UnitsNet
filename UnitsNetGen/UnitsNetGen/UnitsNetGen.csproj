<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>UnitsNetGen</RootNamespace>
    <PackageId>UnitsNetGen</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <AnalyzerDependencyDirectory>$(MSBuildThisFileDirectory)../../Artifacts/UnitsNetGen.Generator/netstandard2.0/</AnalyzerDependencyDirectory>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\UnitsNetGen.Generator\UnitsNetGen.Generator.csproj"
                      PrivateAssets="all"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="../../Artifacts/UnitsNetGen.Generator/netstandard2.0/UnitsNetGen.Generator.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs" />
    <None Include="$(AnalyzerDependencyDirectory)Microsoft.Bcl.AsyncInterfaces.dll;$(AnalyzerDependencyDirectory)System.Buffers.dll;$(AnalyzerDependencyDirectory)System.IO.Pipelines.dll;$(AnalyzerDependencyDirectory)System.Memory.dll;$(AnalyzerDependencyDirectory)System.Numerics.Vectors.dll;$(AnalyzerDependencyDirectory)System.Runtime.CompilerServices.Unsafe.dll;$(AnalyzerDependencyDirectory)System.Text.Encodings.Web.dll;$(AnalyzerDependencyDirectory)System.Text.Json.dll;$(AnalyzerDependencyDirectory)System.Threading.Tasks.Extensions.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="../UnitsNetGen.Generator/buildTransitive/UnitsNetGen.Generator.props"
          Pack="true"
          PackagePath="buildTransitive/UnitsNetGen.props" />
    <None Include="../UnitsNetGen.Generator/buildTransitive/UnitsNetGen.Generator.targets"
          Pack="true"
          PackagePath="buildTransitive/UnitsNetGen.targets" />
    <None Include="../ARCHITECTURE.md" Pack="true" PackagePath="README.md" />
  </ItemGroup>
</Project>
