<Project>
  <PropertyGroup>
    <!-- Custom switch for this repository-only pack/restore automation. It defaults on for the typical Debug development flow. -->
    <UnitsNetGenSampleUpdateLocalPackageOnBuild Condition="'$(UnitsNetGenSampleUpdateLocalPackageOnBuild)' == '' and '$(Configuration)' == 'Debug'">true</UnitsNetGenSampleUpdateLocalPackageOnBuild>
    <UnitsNetGenSampleUpdateLocalPackageOnBuild Condition="'$(UnitsNetGenSampleUpdateLocalPackageOnBuild)' == ''">false</UnitsNetGenSampleUpdateLocalPackageOnBuild>

    <!-- Leading underscores follow the MSBuild convention for implementation-private properties. -->
    <_UnitsNetGenSourceRoot>$(MSBuildThisFileDirectory)..\..\</_UnitsNetGenSourceRoot>
    <_UnitsNetGenSourceProject>$(_UnitsNetGenSourceRoot)UnitsNetGen\UnitsNetGen.csproj</_UnitsNetGenSourceProject>
    <_UnitsNetGenLocalPackStamp>$(UnitsNetGenSampleLocalFeed)\.UnitsNetGen.pack.stamp</_UnitsNetGenLocalPackStamp>
    <!-- MinVer cannot distinguish uncommitted edits, so local packages use a unique override. -->
    <_UnitsNetGenSampleLocalPackageVersion>1.0.0-local.$([System.DateTime]::UtcNow.ToString('yyyyMMddHHmmssfff'))</_UnitsNetGenSampleLocalPackageVersion>
  </PropertyGroup>

  <ItemGroup>
    <_UnitsNetGenLocalPackageInput Include="$(_UnitsNetGenSourceRoot)UnitsNetGen\**\*"
                                   Exclude="$(_UnitsNetGenSourceRoot)UnitsNetGen\bin\**;$(_UnitsNetGenSourceRoot)UnitsNetGen\obj\**" />
    <_UnitsNetGenLocalPackageInput Include="$(_UnitsNetGenSourceRoot)UnitsNetGen.Generator\**\*"
                                   Exclude="$(_UnitsNetGenSourceRoot)UnitsNetGen.Generator\bin\**;$(_UnitsNetGenSourceRoot)UnitsNetGen.Generator\obj\**" />
    <_UnitsNetGenLocalPackageInput Include="$(_UnitsNetGenSourceRoot)ARCHITECTURE.md;$(_UnitsNetGenSourceRoot)README.md;$(_UnitsNetGenSourceRoot)THIRD-PARTY-NOTICES.md;$(_UnitsNetGenSourceRoot)Directory.Build.props;$(_UnitsNetGenSourceRoot)Directory.Build.targets;$(_UnitsNetGenSourceRoot)Directory.Packages.props;$(_UnitsNetGenSourceRoot)..\Docs\Images\logo-32.png" />
  </ItemGroup>

  <Target Name="_PackLocalUnitsNetGenPackage"
          Condition="'$(UnitsNetGenSampleUpdateLocalPackageOnBuild)' == 'true'"
          Inputs="@(_UnitsNetGenLocalPackageInput)"
          Outputs="$(_UnitsNetGenLocalPackStamp)">
    <Message Importance="high" Text="Packing the latest local UnitsNetGen package..." />
    <Exec Command="dotnet pack &quot;$(_UnitsNetGenSourceProject)&quot; --configuration Release --output &quot;$(UnitsNetGenSampleLocalFeed)&quot; -p:MinVerVersionOverride=$(_UnitsNetGenSampleLocalPackageVersion)" />
    <Touch Files="$(_UnitsNetGenLocalPackStamp)" AlwaysCreate="true" />
  </Target>

  <!-- Bootstrap the feed before NuGet tries to resolve the sample's floating PackageReference. -->
  <Target Name="_PackLocalUnitsNetGenPackageBeforeRestore"
          BeforeTargets="Restore;_GenerateRestoreGraphProjectEntry"
          DependsOnTargets="_PackLocalUnitsNetGenPackage"
          Condition="'$(UnitsNetGenSampleUpdateLocalPackageOnBuild)' == 'true'" />

  <!-- Rider can build without a separate restore, so refresh assets before references are resolved. -->
  <Target Name="UpdateLocalUnitsNetGenPackage"
          BeforeTargets="PrepareForBuild"
          DependsOnTargets="_PackLocalUnitsNetGenPackage"
          Condition="'$(UnitsNetGenSampleUpdateLocalPackageOnBuild)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <Message Importance="high" Text="Resolving the latest local UnitsNetGen package..." />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Restore"
             BuildInParallel="false"
             Properties="UnitsNetGenSampleUpdateLocalPackageOnBuild=false;RestoreForceEvaluate=true"
             RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained" />
  </Target>
</Project>
